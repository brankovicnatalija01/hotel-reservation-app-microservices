<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-schema" author="hotelapp">
        <sql>CREATE SCHEMA IF NOT EXISTS hotel_users</sql>
    </changeSet>

    <changeSet id="2-create-roles" author="hotelapp">
        <createTable tableName="roles" schemaName="hotel_users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="3-create-users" author="hotelapp">
        <createTable tableName="users" schemaName="hotel_users">
            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="phone" type="VARCHAR(20)"/>
            <column name="role_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_users_role"
                             references="hotel_users.roles(id)"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="4-seed-roles" author="hotelapp">
        <insert tableName="roles" schemaName="hotel_users">
            <column name="name" value="ROLE_USER"/>
        </insert>
        <insert tableName="roles" schemaName="hotel_users">
            <column name="name" value="ROLE_ADMIN"/>
        </insert>
    </changeSet>

</databaseChangeLog>