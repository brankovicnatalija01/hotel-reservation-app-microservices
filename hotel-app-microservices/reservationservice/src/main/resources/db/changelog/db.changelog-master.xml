<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="1-create-schema" author="hotelapp">
        <sql>CREATE SCHEMA IF NOT EXISTS hotel_reservations</sql>
    </changeSet>

    <changeSet id="2-create-reservations" author="hotelapp">
        <createTable tableName="reservations" schemaName="hotel_reservations">
            <column name="id" type="BIGSERIAL"><constraints primaryKey="true" nullable="false"/></column>
            <column name="user_id" type="BIGINT"><constraints nullable="false"/></column>
            <column name="room_id" type="BIGINT"><constraints nullable="false"/></column>
            <!-- Snapshot fields captured at creation time to avoid repeated cross-service calls -->
            <column name="user_first_name" type="VARCHAR(100)"/>
            <column name="user_last_name" type="VARCHAR(100)"/>
            <column name="room_number" type="VARCHAR(10)"/>
            <column name="room_type_name" type="VARCHAR(100)"/>
            <column name="room_description" type="VARCHAR(1000)"/>
            <column name="price_per_night" type="DECIMAL(10,2)"/>
            <column name="check_in_date" type="DATE"><constraints nullable="false"/></column>
            <column name="check_out_date" type="DATE"><constraints nullable="false"/></column>
            <column name="status" type="VARCHAR(20)"><constraints nullable="false"/></column>
            <column name="total_price" type="DECIMAL(10,2)"/>
        </createTable>
    </changeSet>

</databaseChangeLog>